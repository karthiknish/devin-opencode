{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-devin-plugin",
  "version": "0.1.5",
  "description": "OpenCode plugin (v1 and v2) to connect your Devin account and drive cloud Devin sessions from the OpenCode agent.",
  "type": "module",
  "main": "./src/legacy.ts",
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "devin",
    "cognition",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karthiknish/devin-opencode.git"
  },
  "homepage": "https://github.com/karthiknish/devin-opencode#readme",
  "bugs": {
    "url": "https://github.com/karthiknish/devin-opencode/issues"
  },
  "author": "Karthik Nishanth",
  "exports": {
    ".": {
      "import": "./src/legacy.ts",
      "types": "./src/legacy.ts"
    },
    "./v2": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./legacy": {
      "import": "./src/legacy.ts",
      "types": "./src/legacy.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/plugin": "next",
    "opencode-devin-plugin": "^0.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2"
  }
}
